{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "元精灵",
  "version": "0.1.0",
  "identifier": "com.yuanjingling.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "元精灵",
        "width": 640,
        "height": 380,
        "minWidth": 240,
        "minHeight": 260,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Finance",
    "shortDescription": "悬浮看盘 · 轻量行情面板",
    "longDescription": "元精灵：Windows 悬浮窗口、自选股与可配置列，支持老板键与贴边隐藏。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  }
}
